{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Swiper",
  "version": "0.1.0",
  "identifier": "com.swiper.translator",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Swiper",
        "url": "index.html?window=main",
        "width": 1,
        "height": 1,
        "x": 0,
        "y": 0,
        "visible": false,
        "resizable": false,
        "decorations": false,
        "skipTaskbar": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "Swiper",
    "category": "Utility",
    "shortDescription": "极简划词翻译",
    "longDescription": "极简 Windows 划词翻译桌面软件。性能优先、占用极低、无臃肿功能。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
